# ─── PostgreSQL ───────────────────────────────────────────────
PSQL_USER=admin
PSQL_PASSWORD=admin
PSQL_DB=retail

# ─── Retail API ───────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── vLLM / LLM endpoint ─────────────────────────────────────
DYNAMO_HOST=nemotron-super:8000
NEMOCLAW_MODEL=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-FP8

# ─── NemoClaw ─────────────────────────────────────────────────
NEMOCLAW_SANDBOX_NAME=retail-demo-assistant

# ─── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=<user_id1>,<user_id2>,<user_id3>

# ─── OpenClaw tuning ─────────────────────────────
# streaming mode: 'partial' (token-by-token) or 'full' (wait for complete response)
OPENCLAW_STREAMING_MODE=partial
OPENCLAW_TOOL_PROGRESS=false
OPENCLAW_MAX_TOKENS=8192

# ─── Multi-stack port config ──
DB_EXT_PORT=5432
API_EXT_PORT=8002
SOCAT_INFERENCE_PORT=8000
SOCAT_API_PORT=8001
NEMOCLAW_BIN_PATH=/tmp/nemoclaw-bin-nemotron

# ─── Gateway isolation ──────────
NEMOCLAW_GATEWAY_PORT=8080
NEMOCLAW_DASHBOARD_PORT=18789
OPENSHELL_DOCKER_NETWORK_NAME=openshell-docker

# ─── Dashboard URL (optional) ────────────────────────────────
# Set to the externally-reachable URL for the NemoClaw dashboard.
# Leave empty if not using ingress.
CHAT_UI_URL=