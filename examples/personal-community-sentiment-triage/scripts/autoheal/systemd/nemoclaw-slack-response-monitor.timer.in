[Unit]
Description=Run the NemoClaw Slack response monitor every minute

[Timer]
OnBootSec=3min
OnUnitActiveSec=1min
AccuracySec=10s
Persistent=true
Unit=nemoclaw-slack-response-monitor.service

[Install]
WantedBy=timers.target
