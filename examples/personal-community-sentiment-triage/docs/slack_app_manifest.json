{
    "display_information": {
        "name": "MyUser NemoClaw",
        "description": "Posts community issue updates to a channel and responds to @mentions",
        "background_color": "#76b900"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": false,
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": false
        },
        "bot_user": {
            "display_name": "MyUser NemoClaw",
            "always_online": false
        },
        "slash_commands": [
            {
                "command": "/myuser-nemoclaw",
                "description": "Query NemoClaw",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "im:history",
                "app_mentions:read",
                "channels:history",
                "channels:read",
                "chat:write",
                "commands",
                "reactions:write",
                "users:read",
                "im:read",
                "im:write",
                "mpim:read",
                "mpim:history",
                "im:write.topic"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.channels",
                "message.im",
                "message.mpim"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}
