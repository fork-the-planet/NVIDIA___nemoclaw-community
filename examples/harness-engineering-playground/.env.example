# === Proposer model (diagnoses failures and edits the profile) ===
# Frontier model used to propose fixes. RALPH_API_KEY takes precedence over
# ANTHROPIC_API_KEY so you can use a different key/endpoint for the improvement
# loop than for the model under evaluation.
RALPH_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override the agentic-proposer model for `hep langchain
# ralph` (default: anthropic:claude-opus-4-8). LangChain-style
# provider-prefixed model string.
RALPH_MODEL=

# Optional: custom Anthropic-compatible base URL for the ralph
# proposer. Give the ORIGIN ONLY — e.g. "https://your-inference-endpoint.example.com" —
# not the full request path.
RALPH_BASE_URL=

# Optional: path to a deepagents source checkout containing libs/evals.
# Defaults to the bundled external/deepagents submodule (git submodule update
# --init) — only set this to point at a different checkout instead.
HEP_EVALS_DIR=

# === Model under evaluation (the --model target) ===
# Credentials for the model being tuned. For an openai:-compatible endpoint,
# set both. Other providers use their own standard LangChain vars.
OPENAI_API_BASE=
OPENAI_API_KEY=

# === LangSmith (optional tracing) ===
# The bundled eval suite refuses to start unless tracing is enabled. To run
# fully offline with no LangSmith account, keep the two settings below as-is
# (this satisfies the gate while skipping all LangSmith network calls). To log
# real traces instead, set LANGSMITH_API_KEY and remove LANGSMITH_TEST_TRACKING.
LANGSMITH_TRACING=true
LANGSMITH_TEST_TRACKING=false
LANGSMITH_API_KEY=
